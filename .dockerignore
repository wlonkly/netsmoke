# Dot directories (editor configs, caches, .git, .claude, .venv, etc.)
.*

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
build/
.venv/

# Database files (container gets a fresh or mounted db)
*.db
*.db-wal
*.db-shm

# Frontend build artifacts and deps
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Runtime / dev
.pids/
tmp/
SmokePing/

# Config (users mount their own at runtime)
config.yaml

# macOS
.DS_Store

# Tests not needed in image
backend/tests/
